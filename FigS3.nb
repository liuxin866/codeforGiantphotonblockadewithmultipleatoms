              RowBox[{"\"\<C3\>\"", ",", 
               RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}]}], "}"}]}], 
       ";", "\n", 
       RowBox[{"vars", "=", 
        RowBox[{"Flatten", "[", "vars", "]"}]}], ";", "\n", 
       RowBox[{"S", "=", 
        RowBox[{"NSolve", "[", 
         RowBox[{"equs", ",", "vars"}], "]"}]}], ";", "\n", 
       RowBox[{"C2data", "=", 
        RowBox[{"C2", "/.", 
         RowBox[{"S", "[", 
