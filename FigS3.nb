                RowBox[{"ToExpression", "[", 
                 RowBox[{"StringJoin", "[", 
                  RowBox[{"\"\<C2\>\"", ",", 
                   RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "Na"}], "}"}]}], "]"}], ")"}], "+", 
            RowBox[{
             RowBox[{"E1", "/", "2"}], "*", "C1", "*", 
             RowBox[{"Sqrt", "[", "2", "]"}]}], "+", 
            RowBox[{
             RowBox[{"E1", "/", "2"}], "*", "C3", "*", 
             RowBox[{"Sqrt", "[", "3", "]"}]}], "-", 
            RowBox[{"I", "*", "\[Kappa]", "*", "C2"}], "+", 
            RowBox[{"2", "*", "\[CapitalDelta]", "*", "C2"}]}], "==", "0"}]}],
          "]"}]}], ";", "\n", 
       RowBox[{"equs", "=", 
        RowBox[{"Append", "[", 
         RowBox[{"equs", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{"g", "*", 
