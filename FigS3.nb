                RowBox[{"ToExpression", "[", 
                 RowBox[{"StringJoin", "[", 
                  RowBox[{"\"\<C3\>\"", ",", 
                   RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "Na"}], "}"}]}], "]"}], ")"}], "+", 
