                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              
              RowBox[{"2", "*", "\[CapitalDelta]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C2\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}]}], "==",
              "0"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"g", "*", "C3", "*", 
               RowBox[{"Sqrt", "[", "6", "]"}]}], "+", 
              RowBox[{
               RowBox[{"E1", "/", "2"}], "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C2\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "-", 
              
