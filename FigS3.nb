Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"CloseKernels", "[", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"LaunchKernels", "[", "62", "]"}], ";"}], "\n", "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"ParallelTable", "[", "\n", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Omega]r", "=", 
        RowBox[{"4", "*", "2", "*", "Pi"}]}], ";", "\n", 
       RowBox[{"\[Omega]q", "=", 
        RowBox[{"8", "*", "2", "*", "Pi"}]}], ";", "\n", 
       RowBox[{"Na", "=", "7"}], ";", "\n", "\n", "\n", 
       RowBox[{"\[Gamma]", "=", 
        RowBox[{"0.001", "*", "\[Omega]r"}]}], ";", "\n", 
       RowBox[{"\[Kappa]", "=", 
        RowBox[{"0.001", "*", "\[Omega]r"}]}], ";", "\n", 
       RowBox[{"E1", "=", 
        RowBox[{"3", "*", "\[Kappa]"}]}], ";", "\n", 
       RowBox[{"max1", "=", 
        RowBox[{"15", "*", "\[Kappa]"}]}], ";", "\n", 
       RowBox[{"min1", "=", 
        RowBox[{
         RowBox[{"-", "15"}], "*", "\[Kappa]"}]}], ";", "      ", 
       RowBox[{"(*", 
        RowBox[{
        "max", " ", "and", " ", "min", " ", "value", " ", "of", " ", 
         "\[CapitalDelta]"}], "*)"}], "\n", 
       RowBox[{"segment1", "=", "30"}], ";", "\n", "\n", 
       RowBox[{"\[CapitalDelta]", "=", 
        RowBox[{"N", "[", 
         RowBox[{"min1", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"max1", "-", "min1"}], ")"}], "*", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"m", "-", "1"}], ")"}], "/", "segment1"}]}]}], "]"}]}], 
       ";", 
       RowBox[{"(*", 
        RowBox[{
        "m", " ", "is", " ", "the", " ", "variable", " ", "of", " ", 
         "\[CapitalDelta]", " ", "for", " ", "circulation"}], "*)"}], "\n", 
       RowBox[{"(*", 
        RowBox[{"\[CapitalDelta]", "=", 
         RowBox[{"\[Omega]r", "-", "\[Omega]d"}]}], "*)"}], "\n", 
       RowBox[{"C1", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"E1", "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", " ", 
             RowBox[{"E1", "^", "2"}]}], "+", 
            RowBox[{"4", " ", 
             RowBox[{"\[CapitalDelta]", "^", "2"}]}], "+", 
            RowBox[{"\[Kappa]", "^", "2"}]}], ")"}]}], "]"}]}], ";", "\n", 
       "\n", 
       RowBox[{"g", "=", 
        RowBox[{"0.01", "*", "\[Omega]r"}]}], ";", "\n", "\n", "\n", 
       RowBox[{"equs", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
