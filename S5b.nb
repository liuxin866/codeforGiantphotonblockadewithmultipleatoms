Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CloseKernels", "[", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"LaunchKernels", "[", "62", "]"}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"ParallelTable", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Omega]r", "=", 
        RowBox[{"8", "*", "2", "*", "Pi"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Omega]ge", "=", 
        RowBox[{"8", "*", "2", "*", "Pi"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"g", "=", 
        RowBox[{"0.01", "*", "\[Omega]r"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Gamma]eg", "=", 
        RowBox[{"0.1", "*", "g"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Kappa]", "=", 
        RowBox[{"0.1", "*", "g"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"F", "=", 
        RowBox[{"1.5", "*", "\[Kappa]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"max1", "=", 
        RowBox[{"30", "*", "\[Kappa]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"min1", "=", "0"}], ";", "      ", 
       RowBox[{"(*", 
        RowBox[{
        "max", " ", "and", " ", "min", " ", "value", " ", "of", " ", 
         "\[CapitalDelta]"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"segment1", "=", "100"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalDelta]", "=", 
        RowBox[{"N", "[", 
         RowBox[{"min1", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"max1", "-", "min1"}], ")"}], "*", 
           FractionBox[
            RowBox[{"(", 
             RowBox[{"m", "-", "1"}], ")"}], "segment1"]}]}], "]"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{
        "m", " ", "is", " ", "the", " ", "variable", " ", "of", " ", 
         "\[CapitalDelta]", " ", "for", " ", "circulation"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"\[CapitalDelta]", "=", 
         RowBox[{"\[Omega]r", "-", "\[Omega]d"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"Na", "=", "6"}], ";", "\[IndentingNewLine]", 
       RowBox[{"C1", "=", 
        SqrtBox[
         FractionBox[
          RowBox[{"4", "*", 
           SuperscriptBox["F", "2"], "*", 
           SuperscriptBox["\[CapitalDelta]", "2"]}], 
          RowBox[{
           RowBox[{"8", "*", 
            SuperscriptBox["F", "4"]}], "+", 
           RowBox[{"4", " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Na", "*", 
                SuperscriptBox["g", "2"]}], "-", 
               SuperscriptBox["\[CapitalDelta]", "2"]}], ")"}], "2"]}], "+", 
           RowBox[{"8", "*", 
            SuperscriptBox["F", "2"], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Na", "*", 
               SuperscriptBox["g", "2"]}], "+", 
              SuperscriptBox["\[CapitalDelta]", "2"]}], ")"}]}], "+", 
           RowBox[{
            SuperscriptBox["\[CapitalDelta]", "2"], 
            SuperscriptBox["\[Kappa]", "2"]}]}]]]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"equs", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"\[CapitalDelta]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce1\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              
              RowBox[{"C2", "*", 
               SqrtBox["2"], "*", "g"}], "-", 
              RowBox[{
               FractionBox["I", "2"], "*", "\[Kappa]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce1\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "-", 
              
              RowBox[{
               FractionBox["I", "2"], "*", "\[Gamma]eg", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce1\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              
              RowBox[{"F", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce0\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              
              RowBox[{"\[CapitalDelta]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce1\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}]}], 
             "\[Equal]", "0"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"g", "*", "C1"}], "+", 
              RowBox[{"F", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce1\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "-", 
              
              RowBox[{
               FractionBox["I", "2"], "*", "\[Gamma]eg", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce0\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              
              RowBox[{"\[CapitalDelta]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce0\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}]}], 
             "\[Equal]", "0"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"equs", "=", 
        RowBox[{"Flatten", "[", "equs", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"equs", "=", 
        RowBox[{"Append", "[", 
         RowBox[{"equs", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"2", "*", "\[CapitalDelta]", "*", "C2"}], "+", 
            RowBox[{"F", "*", "C1", "*", 
             SqrtBox["2"]}], "-", 
            RowBox[{"I", "*", "\[Kappa]", "*", "C2"}], "+", 
            RowBox[{"g", "*", 
             RowBox[{"(", 
              RowBox[{"Sum", "[", 
               RowBox[{
                RowBox[{"ToExpression", "[", 
                 RowBox[{"StringJoin", "[", 
                  RowBox[{"\"\<Ce1\>\"", ",", 
                   RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"i", ",", "Na"}], "}"}]}], "]"}], ")"}], "*", 
             SqrtBox["2"]}]}], "\[Equal]", "0"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"vars", "=", 
        RowBox[{"{", 
         RowBox[{"C2", ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"ToExpression", "[", 
             RowBox[{"StringJoin", "[", 
              RowBox[{"\"\<Ce1\>\"", ",", 
               RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"ToExpression", "[", 
             RowBox[{"StringJoin", "[", 
              RowBox[{"\"\<Ce0\>\"", ",", 
               RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}]}], "}"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"vars", "=", 
        RowBox[{"Flatten", "[", "vars", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"S", "=", 
        RowBox[{"NSolve", "[", 
         RowBox[{"equs", ",", "vars"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"C2data", "=", 
        RowBox[{"C2", "/.", 
         RowBox[{"S", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Ce1data", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"ToExpression", "[", 
            RowBox[{"StringJoin", "[", 
             RowBox[{"\"\<Ce1\>\"", ",", 
              RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}], "/.", 
           RowBox[{"S", "[", 
            RowBox[{"[", 
             RowBox[{"1", ",", 
              RowBox[{"i", "+", "1"}]}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"logg20", "=", 
        RowBox[{"Chop", "[", 
         RowBox[{"Log10", "[", 
          RowBox[{
           FractionBox["2", 
            RowBox[{"C1", "*", 
             RowBox[{"Conjugate", "[", "C1", "]"}]}]], "*", 
           RowBox[{"(", 
            FractionBox["C2data", "C1"], ")"}], "*", 
           RowBox[{"(", 
            FractionBox[
             RowBox[{"Conjugate", "[", "C2data", "]"}], 
             RowBox[{"Conjugate", "[", "C1", "]"}]], ")"}]}], "]"}], "]"}]}], 
       ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[CapitalDelta]", "/", "\[Kappa]"}], ",", "logg20"}], 
        "}"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", "1", ",", 
        RowBox[{"100", "+", "1"}], ",", "1"}], "}"}], ",", 
      RowBox[{"Method", "\[Rule]", "\"\<FinestGrained\>\""}]}], 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Circulation", " ", "is", " ", 
    RowBox[{"ended", "."}]}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"data", ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
     "\"\<(\!\(\*SubscriptBox[\(\[Omega]\), \(a\)]\)-\!\(\*SubscriptBox[\(\
\[Omega]\), \(da\)]\))/\!\(\*SubscriptBox[\(\[Kappa]\), \(a\)]\)\>\"", ",", 
      "\"\<\!\(\*SubscriptBox[\(log\), \(10\)]\)\!\(\*SuperscriptBox[\(g\), \
\((2)\)]\)(0)\>\""}], "}"}]}], ",", 
   RowBox[{"BaseStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"FontSize", "\[Rule]", "16"}], ",", 
      RowBox[{"FontFamily", "\[Rule]", "\"\<Calibri\>\""}]}], "}"}]}], ",", 
   RowBox[{"Joined", "\[Rule]", "False"}], ",", 
