          RowBox[{"i", "++"}], ";", "\[IndentingNewLine]", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"j", "=", "0"}], ",", 
            RowBox[{"j", "<", "columncut"}], ",", 
            RowBox[{
             RowBox[{"j", "++"}], ";", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"equ", "[", 
               RowBox[{"[", 
                RowBox[{"matrixvariablef", "+", 
                 RowBox[{"(", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"i", "-", "1"}], ")"}], "*", "columncut"}], "+", 
                    "j"}], ")"}], ")"}]}], "]"}], "]"}], "=", 
              RowBox[{
               RowBox[{"ToExpression", "[", 
