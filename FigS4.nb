                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce0\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              RowBox[{"\[CapitalDelta]", "*", 
               RowBox[{"ToExpression", "[", 
