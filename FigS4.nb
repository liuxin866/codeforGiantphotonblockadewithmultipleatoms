                 RowBox[{"\"\<Ce0\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}]}], 
             "\[Equal]", "0"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"equs", "=", 
        RowBox[{"Flatten", "[", "equs", "]"}]}], ";", "\[IndentingNewLine]", 
