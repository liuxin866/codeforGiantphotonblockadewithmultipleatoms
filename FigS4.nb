       RowBox[{"min1", "=", 
        RowBox[{"15", "*", "\[Kappa]"}]}], ";", "      ", 
       RowBox[{"(*", 
        RowBox[{
        "max", " ", "and", " ", "min", " ", "value", " ", "of", " ", 
         "\[CapitalDelta]"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"segment1", "=", "30"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalDelta]", "=", 
        RowBox[{"N", "[", 
         RowBox[{"min1", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"max1", "-", "min1"}], ")"}], "*", 
           FractionBox[
            RowBox[{"(", 
             RowBox[{"m", "-", "1"}], ")"}], "segment1"]}]}], "]"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{
