            RowBox[{
             RowBox[{
              RowBox[{"\[CapitalDelta]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce1\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              RowBox[{"C2", "*", 
               SqrtBox["2"], "*", "g"}], "-", 
              RowBox[{
               FractionBox["I", "2"], "*", "\[Kappa]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce1\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "-", 
              RowBox[{
