                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}]}], 
             "\[Equal]", "0"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"g", "*", "C1"}], "+", 
              RowBox[{"F", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
