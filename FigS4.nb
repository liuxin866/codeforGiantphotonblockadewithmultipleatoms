                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce1\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              RowBox[{"F", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<Ce0\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              RowBox[{"\[CapitalDelta]", "*", 
