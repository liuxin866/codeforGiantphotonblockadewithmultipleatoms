Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CloseKernels", "[", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"LaunchKernels", "[", "62", "]"}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"ParallelTable", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Omega]r", "=", 
        RowBox[{"8", "*", "2", "*", "Pi"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Omega]ge", "=", 
        RowBox[{"8", "*", "2", "*", "Pi"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"g", "=", 
        RowBox[{"0.01", "*", "\[Omega]r"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Gamma]eg", "=", 
        RowBox[{"0.1", "*", "g"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Kappa]", "=", 
        RowBox[{"0.1", "*", "g"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"F", "=", 
        RowBox[{"1.5", "*", "\[Kappa]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"max1", "=", 
        RowBox[{"30", "*", "\[Kappa]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"min1", "=", 
        RowBox[{"15", "*", "\[Kappa]"}]}], ";", "      ", 
       RowBox[{"(*", 
        RowBox[{
        "max", " ", "and", " ", "min", " ", "value", " ", "of", " ", 
         "\[CapitalDelta]"}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"segment1", "=", "30"}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalDelta]", "=", 
        RowBox[{"N", "[", 
         RowBox[{"min1", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"max1", "-", "min1"}], ")"}], "*", 
           FractionBox[
            RowBox[{"(", 
             RowBox[{"m", "-", "1"}], ")"}], "segment1"]}]}], "]"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{
        "m", " ", "is", " ", "the", " ", "variable", " ", "of", " ", 
         "\[CapitalDelta]", " ", "for", " ", "circulation"}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"\[CapitalDelta]", "=", 
         RowBox[{"\[Omega]r", "-", "\[Omega]d"}]}], "*)"}], 
       "\[IndentingNewLine]", 
       RowBox[{"Na", "=", "5"}], ";", "\[IndentingNewLine]", 
       RowBox[{"C1", "=", 
        SqrtBox[
         FractionBox[
          RowBox[{"4", "*", 
           SuperscriptBox["F", "2"], "*", 
           SuperscriptBox["\[CapitalDelta]", "2"]}], 
          RowBox[{
           RowBox[{"8", "*", 
            SuperscriptBox["F", "4"]}], "+", 
           RowBox[{"4", " ", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Na", "*", 
                SuperscriptBox["g", "2"]}], "-", 
               SuperscriptBox["\[CapitalDelta]", "2"]}], ")"}], "2"]}], "+", 
           RowBox[{"8", "*", 
            SuperscriptBox["F", "2"], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Na", "*", 
               SuperscriptBox["g", "2"]}], "+", 
              SuperscriptBox["\[CapitalDelta]", "2"]}], ")"}]}], "+", 
           RowBox[{
            SuperscriptBox["\[CapitalDelta]", "2"], 
            SuperscriptBox["\[Kappa]", "2"]}]}]]]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"equs", "=", 
