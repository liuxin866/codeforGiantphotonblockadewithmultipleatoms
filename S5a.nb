Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"CloseKernels", "[", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"LaunchKernels", "[", "62", "]"}], ";"}], "\n", "\n", "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"ParallelTable", "[", "\n", 
     RowBox[{
      RowBox[{
       RowBox[{"\[Omega]r", "=", 
        RowBox[{"4", "*", "2", "*", "Pi"}]}], ";", "\n", 
       RowBox[{"\[Omega]q", "=", 
        RowBox[{"8", "*", "2", "*", "Pi"}]}], ";", "\n", 
       RowBox[{"Na", "=", "7"}], ";", "\n", "\n", "\n", 
       RowBox[{"\[Gamma]", "=", 
        RowBox[{"0.001", "*", "\[Omega]r"}]}], ";", "\n", 
       RowBox[{"\[Kappa]", "=", 
        RowBox[{"0.001", "*", "\[Omega]r"}]}], ";", "\n", 
       RowBox[{"E1", "=", 
        RowBox[{"3", "*", "\[Kappa]"}]}], ";", "\n", 
       RowBox[{"max1", "=", 
        RowBox[{"30", "*", "\[Kappa]"}]}], ";", "\n", 
       RowBox[{"min1", "=", "0"}], ";", "      ", 
       RowBox[{"(*", 
        RowBox[{
        "max", " ", "and", " ", "min", " ", "value", " ", "of", " ", 
         "\[CapitalDelta]"}], "*)"}], "\n", 
       RowBox[{"segment1", "=", "50"}], ";", "\n", "\n", 
       RowBox[{"\[CapitalDelta]", "=", 
        RowBox[{"N", "[", 
         RowBox[{"min1", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"max1", "-", "min1"}], ")"}], "*", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"m", "-", "1"}], ")"}], "/", "segment1"}]}]}], "]"}]}], 
       ";", 
       RowBox[{"(*", 
        RowBox[{
        "m", " ", "is", " ", "the", " ", "variable", " ", "of", " ", 
         "\[CapitalDelta]", " ", "for", " ", "circulation"}], "*)"}], "\n", 
       RowBox[{"(*", 
        RowBox[{"\[CapitalDelta]", "=", 
         RowBox[{"\[Omega]r", "-", "\[Omega]d"}]}], "*)"}], "\n", 
       RowBox[{"C1", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"E1", "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", " ", 
             RowBox[{"E1", "^", "2"}]}], "+", 
            RowBox[{"4", " ", 
             RowBox[{"\[CapitalDelta]", "^", "2"}]}], "+", 
            RowBox[{"\[Kappa]", "^", "2"}]}], ")"}]}], "]"}]}], ";", "\n", 
       "\n", 
       RowBox[{"g", "=", 
        RowBox[{"0.01", "*", "\[Omega]r"}]}], ";", "\n", "\n", "\n", 
       RowBox[{"equs", "=", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"g", "*", "C2", "*", 
               RowBox[{"Sqrt", "[", "2", "]"}]}], "+", 
              RowBox[{
               RowBox[{"E1", "/", "2"}], "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C3\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "-", 
              
              RowBox[{
               RowBox[{"I", "/", "2"}], "*", "\[Gamma]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C2\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              
              RowBox[{"2", "*", "\[CapitalDelta]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C2\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}]}], "==",
              "0"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"g", "*", "C3", "*", 
               RowBox[{"Sqrt", "[", "6", "]"}]}], "+", 
              RowBox[{
               RowBox[{"E1", "/", "2"}], "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C2\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "-", 
              
              RowBox[{
               RowBox[{"I", "/", "2"}], "*", "\[Kappa]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C3\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "-", 
              
              RowBox[{
               RowBox[{"I", "/", "2"}], "*", "\[Gamma]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C3\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              
              RowBox[{"\[CapitalDelta]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C3\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], "+", 
              
              RowBox[{"2", "*", "\[CapitalDelta]", "*", 
               RowBox[{"ToExpression", "[", 
                RowBox[{"StringJoin", "[", 
                 RowBox[{"\"\<C3\>\"", ",", 
                  RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}]}], "==",
              "0"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}]}], ";", "\n", 
       RowBox[{"equs", "=", 
        RowBox[{"Flatten", "[", "equs", "]"}]}], ";", "\n", 
       RowBox[{"equs", "=", 
        RowBox[{"Append", "[", 
         RowBox[{"equs", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{"g", "*", 
                RowBox[{"Sqrt", "[", "2", "]"}], "*", 
                RowBox[{"ToExpression", "[", 
                 RowBox[{"StringJoin", "[", 
                  RowBox[{"\"\<C2\>\"", ",", 
                   RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "Na"}], "}"}]}], "]"}], ")"}], "+", 
            RowBox[{
             RowBox[{"E1", "/", "2"}], "*", "C1", "*", 
             RowBox[{"Sqrt", "[", "2", "]"}]}], "+", 
            RowBox[{
             RowBox[{"E1", "/", "2"}], "*", "C3", "*", 
             RowBox[{"Sqrt", "[", "3", "]"}]}], "-", 
            RowBox[{"I", "*", "\[Kappa]", "*", "C2"}], "+", 
            RowBox[{"2", "*", "\[CapitalDelta]", "*", "C2"}]}], "==", "0"}]}],
          "]"}]}], ";", "\n", 
       RowBox[{"equs", "=", 
        RowBox[{"Append", "[", 
         RowBox[{"equs", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{"g", "*", 
                RowBox[{"Sqrt", "[", "6", "]"}], "*", 
                RowBox[{"ToExpression", "[", 
                 RowBox[{"StringJoin", "[", 
                  RowBox[{"\"\<C3\>\"", ",", 
                   RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"i", ",", "Na"}], "}"}]}], "]"}], ")"}], "+", 
            RowBox[{
             RowBox[{"E1", "/", "2"}], "*", "C2", "*", 
             RowBox[{"Sqrt", "[", "3", "]"}]}], "-", 
            RowBox[{
             RowBox[{"I", "/", "2"}], "*", "\[Kappa]", "*", "C3", "*", "3"}], 
            "+", 
            RowBox[{"3", "*", "\[CapitalDelta]", "*", "C3"}]}], "==", "0"}]}],
          "]"}]}], ";", "\n", "\n", 
       RowBox[{"vars", "=", 
        RowBox[{"{", 
         RowBox[{"C2", ",", "C3", ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"ToExpression", "[", 
             RowBox[{"StringJoin", "[", 
              RowBox[{"\"\<C2\>\"", ",", 
               RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}], ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"ToExpression", "[", 
             RowBox[{"StringJoin", "[", 
              RowBox[{"\"\<C3\>\"", ",", 
               RowBox[{"ToString", "[", "i", "]"}]}], "]"}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}]}], "}"}]}], 
       ";", "\n", 
       RowBox[{"vars", "=", 
        RowBox[{"Flatten", "[", "vars", "]"}]}], ";", "\n", 
       RowBox[{"S", "=", 
        RowBox[{"NSolve", "[", 
         RowBox[{"equs", ",", "vars"}], "]"}]}], ";", "\n", 
       RowBox[{"C2data", "=", 
        RowBox[{"C2", "/.", 
         RowBox[{"S", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";", "\n", 
       RowBox[{"C3data", "=", 
        RowBox[{"C3", "/.", 
         RowBox[{"S", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], ";", "\n", 
       RowBox[{"logg20", "=", 
        RowBox[{"Log10", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", "C2data", "]"}], "^", "2"}], "*", "2"}], 
            "+", 
            RowBox[{
             RowBox[{
              RowBox[{"Abs", "[", "C3data", "]"}], "^", "2"}], "*", "6"}]}], 
           ")"}], "/", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"E1", "^", "2"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", " ", 
                RowBox[{"E1", "^", "2"}]}], "+", 
               RowBox[{"4", " ", 
                RowBox[{"\[CapitalDelta]", "^", "2"}]}], "+", 
               RowBox[{"\[Kappa]", "^", "2"}]}], ")"}]}], ")"}], "^", "2"}]}],
