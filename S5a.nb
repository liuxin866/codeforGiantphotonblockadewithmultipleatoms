       RowBox[{"segment1", "=", "50"}], ";", "\n", "\n", 
       RowBox[{"\[CapitalDelta]", "=", 
        RowBox[{"N", "[", 
         RowBox[{"min1", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"max1", "-", "min1"}], ")"}], "*", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"m", "-", "1"}], ")"}], "/", "segment1"}]}]}], "]"}]}], 
       ";", 
       RowBox[{"(*", 
        RowBox[{
        "m", " ", "is", " ", "the", " ", "variable", " ", "of", " ", 
         "\[CapitalDelta]", " ", "for", " ", "circulation"}], "*)"}], "\n", 
       RowBox[{"(*", 
        RowBox[{"\[CapitalDelta]", "=", 
         RowBox[{"\[Omega]r", "-", "\[Omega]d"}]}], "*)"}], "\n", 
       RowBox[{"C1", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"E1", "^", "2"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", " ", 
             RowBox[{"E1", "^", "2"}]}], "+", 
            RowBox[{"4", " ", 
             RowBox[{"\[CapitalDelta]", "^", "2"}]}], "+", 
            RowBox[{"\[Kappa]", "^", "2"}]}], ")"}]}], "]"}]}], ";", "\n", 
       "\n", 
       RowBox[{"g", "=", 
        RowBox[{"0.01", "*", "\[Omega]r"}]}], ";", "\n", "\n", "\n", 
       RowBox[{"equs", "=", 
        RowBox[{"Table", "[", 
