            RowBox[{"{", 
             RowBox[{"i", ",", "1", ",", "Na"}], "}"}]}], "]"}]}], "}"}]}], 
       ";", "\n", 
       RowBox[{"vars", "=", 
        RowBox[{"Flatten", "[", "vars", "]"}]}], ";", "\n", 
       RowBox[{"S", "=", 
        RowBox[{"NSolve", "[", 
         RowBox[{"equs", ",", "vars"}], "]"}]}], ";", "\n", 
       RowBox[{"C2data", "=", 
        RowBox[{"C2", "/.", 
         RowBox[{"S", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";", "\n", 
       RowBox[{"C3data", "=", 
