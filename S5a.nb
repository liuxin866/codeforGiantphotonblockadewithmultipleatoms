\((2)\)]\)(0)\>\""}], "}"}]}], ",", 
   RowBox[{"BaseStyle", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"FontSize", "->", "20"}], ",", 
      RowBox[{"FontFamily", "->", "\"\<Calibri\>\""}]}], "}"}]}], ",", 
   RowBox[{"Joined", "->", "False"}], ",", 
   RowBox[{"PlotStyle", "->", 
